# Port the proxy listens on (default: 4000)
PORT=4000

# Extra allowed origin (e.g. your frontend or app URL)
# localhost:3000 and localhost:5173 are always allowed
ALLOWED_ORIGIN=http://localhost:8080

# Optional: production-style limits (defaults are fine for side projects)
# FETCH_TIMEOUT_MS=15000
# MAX_RESPONSE_SIZE=5242880
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=60
